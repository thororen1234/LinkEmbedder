{
  "name": "linkembedder",
  "version": "1.0.0",
  "description": "Unified social media embed-fix server for Twitter, Instagram, Reddit, TikTok, Bluesky, Pixiv, and Tumblr",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "cheerio": "^1.2.0",
    "hono": "^4.12.26",
    "sharp": "^0.35.2",
    "zip-lib": "^1.4.0"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}